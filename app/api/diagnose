export default async function handler(req, res) {
  try {
    const { problem } = req.body || {};

    if (!problem || typeof problem !== "string" || problem.trim().length < 3) {
      return res.status(400).json({
        result: "Please describe the problem clearly (e.g. 'engine overheating')."
      });
    }

    const cleanProblem = problem.trim().slice(0, 500);

    const response = await fetch("https://api.openai.com/v1/responses", {
      method: "POST",
      headers: {
        "Authorization": `Bearer ${process.env.OPENAI_API_KEY}`,
        "Content-Type": "application/json"
      },
      body: JSON.stringify({
        model: "gpt-4.1-mini",
        input: `You are a car diagnostic expert. Diagnose this issue clearly: ${cleanProblem}`
      })
    });

    if (!response.ok) {
      return res.status(500).json({
        result: "AI service is temporarily unavailable. Try again."
      });
    }

    const data = await response.json();

    const result =
      data?.output?.[0]?.content?.[0]?.text ||
      "Could not diagnose. Try rephrasing.";

    return res.status(200).json({ result });

  } catch (error) {
    return res.status(500).json({
      result: "Something went wrong. Please try again."
    });
  }
}