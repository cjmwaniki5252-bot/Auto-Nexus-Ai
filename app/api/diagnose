export async function POST(req: Request) {
  try {
    const body = await req.json();

    const problem = body.problem;

    if (!problem) {
      return new Response(
        JSON.stringify({ error: "No problem provided" }),
        { status: 400 }
      );
    }

    // Fake AI logic (we upgrade later)
    let response = "";

    if (problem.toLowerCase().includes("engine")) {
      response = "Possible engine misfire or fuel system issue.";
    } else if (problem.toLowerCase().includes("brake")) {
      response = "Brake pads may be worn or fluid is low.";
    } else {
      response = "Issue unclear. Recommend full diagnostic scan.";
    }

    return new Response(JSON.stringify({ result: response }), {
      status: 200,
    });
  } catch (err) {
    return new Response(JSON.stringify({ error: "Server error" }), {
      status: 500,
    });
  }
}