export async function POST(req) {
  try {
    const body = await req.json().catch(() => ({}));
    let issue = body.issue || "";

    if (!issue || typeof issue !== "string") {
      return Response.json({
        result: "Please enter a valid issue."
      });
    }

    issue = issue.trim().toLowerCase();

    let result = "Unknown issue. Please check engine, coolant, or battery.";

    if (issue.includes("overheat")) {
      result = "Possible causes: low coolant, faulty thermostat, radiator blockage.";
    } else if (issue.includes("battery")) {
      result = "Battery may be dead or alternator issue.";
    } else if (issue.includes("brake")) {
      result = "Brake pads worn or brake fluid low.";
    }

    return Response.json({ result });

  } catch (error) {
    return Response.json({
      result: "System error. Try again."
    });
  }
}